   "outputs": [],
   "source": [
    "# PSEUDO-CODE for modifying Faster-RCNN head for fine-tuning\n",
    "import torch\n",
    "import torchvision\n",
    "from torchvision.models.detection.faster_rcnn import FastRCNNPredictor\n",
    "\n",
    "def get_fine_tuned_model(num_classes, pretrained_weights_name='COCO_V1'):\n",
    "    # Load a model pre-trained on COCO\n",
    "    if pretrained_weights_name == 'COCO_V1':\n",
    "        weights = torchvision.models.detection.FasterRCNN_ResNet50_FPN_Weights.COCO_V1\n",
    "    # Add more options here if needed, e.g., FasterRCNN_ResNet50_FPN_Weights.DEFAULT for latest\n",
    "    else:\n",
    "        weights = None # Or handle error / specific weights object\n",
    "\n",
    "    model = torchvision.models.detection.fasterrcnn_resnet50_fpn(weights=weights)\n",
    "\n",
    "    # Get the number of input features for the classifier\n",
    "    in_features = model.roi_heads.box_predictor.cls_score.in_features\n",
    "\n",
    "    # Replace the pre-trained head with a new one suitable for num_classes\n",
    "    # num_classes typically includes the background class (e.g., 1 class 'person' + 1 'background' = 2)\n",
    "    model.roi_heads.box_predictor = FastRCNNPredictor(in_features, num_classes)\n",
    "    \n",
    "    print(f\"Model head replaced. Ready for fine-tuning with {num_classes} classes.\")\n",
    "    return model\n",
    "\n",
    "# Example usage:\n",
    "# If fine-tuning for 'person' class only (+ background)\n",
    "# target_num_classes = 2 \n",
    "# fine_tuning_model = get_fine_tuned_model(target_num_classes)\n",
    "\n",
    "# If you have a GPU, move the model to GPU\n",
    "# device = torch.device('cuda') if torch.cuda.is_available() else torch.device('cpu')\n",
    "# fine_tuning_model.to(device)"
   ],
